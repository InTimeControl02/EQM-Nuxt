# API Base URL
NUXT_PUBLIC_API_BASE=http://localhost:8000/api/v1

# Public token
NUXT_PUBLIC_API_PUBLIC_TOKEN=your_public_token_here

# Private token
API_PRIVATE_TOKEN=your_private_token_here

# S3 public base URL for frontend image rendering
NUXT_PUBLIC_API_STORAGE_BASE=https://your-bucket.s3.your-region.amazonaws.com
